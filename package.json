{
  "name": "brp-demo",
  "version": "0.3.1",
  "private": true,
  "description": "Interactive read-only BRP catalog, dealer portal, and manager portal demo",
  "author": "razumv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/razumv/brp-demo.git"
  },
  "homepage": "https://razumv.github.io/brp-demo/",
  "bugs": {
    "url": "https://github.com/razumv/brp-demo/issues"
  },
  "keywords": [
    "brp",
    "read-only-demo",
    "dealer-portal",
    "manager-portal",
    "nextjs",
    "github-pages",
    "tailwindcss",
    "shadcn-ui"
  ],
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "DEPLOY_TARGET=github-pages PWA_BASE_PATH=/brp-demo next build && npm run pwa:generate && npm run pwa:validate",
    "pwa:generate": "node scripts/generate-pwa.mjs",
    "pwa:validate": "node scripts/validate-pwa.mjs",
    "start": "next start",
    "test:e2e": "playwright test",
    "test:e2e:dealer": "playwright test -c playwright.dealer.config.ts",
    "test:e2e:dealer-pages": "node scripts/test-dealer-pages.mjs",
    "test:dealer-state": "tsx --test tests/dealer-*.test.ts",
    "test:e2e:mobile": "playwright test tests/e2e/admin-mobile-contract.spec.ts",
    "theme:astryx:build": "astryx theme build src/themes/neutral/neutralTheme.ts",
    "theme:astryx:check": "node scripts/check-astryx-theme.mjs",
    "test:appearance": "tsx --test tests/appearance-*.test.ts tests/astryx-*.test.ts",
    "test:e2e:appearance": "node scripts/test-appearance-production.mjs",
    "test:e2e:appearance:matrix": "playwright test -c playwright.appearance-matrix.config.ts",
    "test:e2e:appearance:real-devices": "node scripts/run-real-device-matrix.mjs",
    "test:e2e:appearance:pages": "node scripts/test-appearance-pages.mjs",
    "test:e2e:appearance:foundation": "NEXT_PUBLIC_APPEARANCE_FOUNDATION_PROBE=1 npm run test:e2e:appearance -- tests/e2e/astryx-foundation.spec.ts --project=chromium",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test:dealer-state && npm run build"
  },
  "dependencies": {
    "@astryxdesign/core": "0.1.7",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/figtree": "5.3.0",
    "@stylexjs/stylex": "0.19.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astryxdesign/cli": "0.1.7",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "browserstack-local": "^1.5.13",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "shadcn": "^4.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "workbox-build": "^7.4.1"
  }
}
